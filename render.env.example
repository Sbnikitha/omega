# =============================================================================
# OMEGA — ONE env file for Render
# =============================================================================
# SINGLE SERVICE (recommended free tier):
#   Use render-single.yaml → paste this file ONCE into the omega service env.
#   After deploy set: FRONTEND_URL=https://YOUR-SERVICE.onrender.com
#   Leave OMEGA_API_URL=http://127.0.0.1:8001 (internal — do not change).
#
# TWO SERVICES (render.yaml):
#   Paste the SAME file into BOTH omega-backend AND omega-web.
#   Set FRONTEND_URL + OMEGA_API_URL to your two .onrender.com URLs.
#
# DO NOT commit render.env with real keys.
# =============================================================================

# --- Shared secrets (both services) ------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here

# --- Backend: Langfuse -------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- Backend: LLM swarm ------------------------------------------------------
GOOGLE_API_KEY=your-gemini-api-key-here
OMEGA_MODEL=gemini-2.0-flash
OMEGA_DEMO_MODE=true
PIONEER_API_KEY=
PIONEER_AS_LLM=false
PIONEER_MODEL_ID=fastino/gliner2-base-v1
PIONEER_CHAT_MODEL=gpt-4o-mini

# --- Backend: sponsors (optional — leave blank for demo mode) ------------------
SENSO_API_KEY=
SENSO_GEO_QUESTION_ID=
SENSO_BASE_URL=https://apiv2.senso.ai/api/v1
COMPOSIO_API_KEY=
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_ACCESS_TOKEN=
AIRBYTE_CONNECTOR_ID=
AIRBYTE_RSS_URL=https://www.githubstatus.com/history.rss
TFY_HOST=
TFY_API_KEY=

# --- Backend: server / storage -----------------------------------------------
OMEGA_API_HOST=0.0.0.0
OMEGA_CLICKHOUSE_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# --- x402 payments -----------------------------------------------------------
OMEGA_X402_ENABLED=true
OMEGA_X402_PRICE_USD=0.02
OMEGA_X402_PAY_TO=omega-agent@agentic.market
OMEGA_X402_DEMO_TOKEN=demo-paid
OMEGA_PAYMENT_TOKEN=demo-paid

# --- URLs (set AFTER deploy in Render dashboard — not localhost) ---
# Two services:
# FRONTEND_URL=https://YOUR-omega-web.onrender.com
# OMEGA_API_URL=https://YOUR-omega-backend.onrender.com
#
# Single service (render-single.yaml):
# FRONTEND_URL=https://YOUR-SERVICE.onrender.com
# OMEGA_API_URL=http://127.0.0.1:8001
FRONTEND_URL=
OMEGA_API_URL=

# --- Web only (harmless on backend if pasted) --------------------------------
NODE_ENV=production
