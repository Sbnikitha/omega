# Langfuse (required for full observability loop)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM — Gemini (default) or Pioneer (set PIONEER_AS_LLM=true)
GOOGLE_API_KEY=your-gemini-api-key
OMEGA_MODEL=gemini-2.0-flash
OPENAI_API_KEY=sk-...                    # OpenUI Copilot + optional LLM fallback

# Pioneer inference
PIONEER_API_KEY=pio_sk_...
PIONEER_AS_LLM=false
PIONEER_MODEL_ID=fastino/gliner2-base-v1
PIONEER_CHAT_MODEL=gpt-4o-mini

# Senso cited.md publish
SENSO_API_KEY=tgr_...
SENSO_GEO_QUESTION_ID=
SENSO_BASE_URL=https://apiv2.senso.ai/api/v1

# Composio open-web tools
COMPOSIO_API_KEY=

# Airbyte Agent Engine
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_CONNECTOR_ID=
AIRBYTE_RSS_URL=https://www.githubstatus.com/history.rss

# TrueFoundry deploy
TFY_HOST=https://your-org.truefoundry.cloud
TFY_API_KEY=

# Render (set in Render dashboard; used for CORS)
FRONTEND_URL=https://omega-web.onrender.com

# Optional Redis for event bus (falls back to in-memory)
REDIS_URL=redis://localhost:6379/0

# API
OMEGA_API_HOST=0.0.0.0
OMEGA_API_PORT=8001
OMEGA_DEMO_MODE=false

# ClickHouse incident store (replaces unsafe incidents.json when enabled)
OMEGA_CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# x402 agent payments (402 until X-402-Payment header)
OMEGA_X402_ENABLED=true
OMEGA_X402_PRICE_USD=0.02
OMEGA_X402_PAY_TO=omega-agent@agentic.market
OMEGA_X402_DEMO_TOKEN=demo-paid

# Guild commander agent (see guild/README.md)
# OMEGA_API_URL=https://omega-backend.onrender.com
# OMEGA_PAYMENT_TOKEN=demo-paid
