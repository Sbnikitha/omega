# Langfuse (required for full observability loop)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM
GOOGLE_API_KEY=your-gemini-api-key
OMEGA_MODEL=gemini-2.0-flash

# Optional Redis for event bus (falls back to in-memory)
REDIS_URL=redis://localhost:6379/0

# API
OMEGA_API_HOST=0.0.0.0
OMEGA_API_PORT=8001
OMEGA_DEMO_MODE=false

# ClickHouse incident store (replaces unsafe incidents.json when enabled)
OMEGA_CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
